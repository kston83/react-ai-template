{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx shadcn@latest add *)",
      "Bash(npx tsc --noEmit)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hook": ".claude/hooks/protect-files.sh"
      },
      {
        "matcher": "Bash",
        "hook": ".claude/hooks/block-dangerous-commands.sh"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hook": ".claude/hooks/lint-after-edit.sh"
      }
    ]
  }
}
